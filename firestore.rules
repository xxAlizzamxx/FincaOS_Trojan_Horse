rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: user's profile
    function getUserProfile() {
      return get(/databases/$(database)/documents/perfiles/$(request.auth.uid)).data;
    }

    // Helper: user belongs to community
    function belongsToCommunity(comunidadId) {
      return isAuth() && getUserProfile().comunidad_id == comunidadId;
    }

    // Helper: user is admin or presidente
    function isAdmin() {
      return isAuth() && getUserProfile().rol in ['admin', 'presidente'];
    }

    // Helper: user is admin/presidente AND belongs to the given community
    // Reads getUserProfile() ONCE to avoid hitting the external-read limit
    function isAdminOfCommunity(comunidadId) {
      let p = getUserProfile();
      return isAuth()
        && p.rol in ['admin', 'presidente']
        && p.comunidad_id == comunidadId;
    }

    // Helper: user is mediador AND belongs to the given community
    function isMediadorOfCommunity(comunidadId) {
      let p = getUserProfile();
      return isAuth()
        && p.rol == 'mediador'
        && p.comunidad_id == comunidadId;
    }

    // Helper: user can manage a mediation (admin, presidente, or mediador of community)
    function canManageMediacion(comunidadId) {
      let p = getUserProfile();
      return isAuth()
        && p.comunidad_id == comunidadId
        && p.rol in ['admin', 'presidente', 'mediador'];
    }

    // Comunidades (public read for invite page)
    match /comunidades/{comunidadId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth();
    }

    // Perfiles
    // - Lectura pública para la página de invitación (muestra count de vecinos sin login)
    // - Solo usuarios autenticados pueden leer perfiles de su comunidad en el resto de la app
    // - El usuario solo puede crear/actualizar su propio perfil (o admin el de cualquiera)
    match /perfiles/{userId} {
      allow read: if true;   // invite page necesita leer sin auth
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if isAuth() && (request.auth.uid == userId || isAdmin());
    }

    // Categorias de incidencia (read-only, seeded by admin)
    match /categorias_incidencia/{catId} {
      allow read: if true;
      allow write: if false;
    }

    // Incidencias
    match /incidencias/{incidenciaId} {
      allow read: if isAuth();
      allow create: if isAuth() && belongsToCommunity(request.resource.data.comunidad_id);
      allow update: if isAuth() && belongsToCommunity(resource.data.comunidad_id);
    }

    // Comentarios
    match /comentarios/{comentarioId} {
      allow read: if isAuth();
      allow create: if isAuth();
    }

    // Incidencia afectados
    match /incidencia_afectados/{afectadoId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow delete: if isAuth();
    }

    // Anuncios
    match /anuncios/{anuncioId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow delete: if isAuth();
    }

    // Documentos — lectura para todos los autenticados; escritura solo admin/presidente
    match /documentos/{docId} {
      allow read: if isAuth() && belongsToCommunity(resource.data.comunidad_id);
      allow create: if isAdmin() && belongsToCommunity(request.resource.data.comunidad_id);
      allow delete: if isAdmin() && belongsToCommunity(resource.data.comunidad_id);
    }

    // Votaciones + votos (subcollection)
    match /votaciones/{votacionId} {
      allow read: if isAuth();
      allow create: if isAdmin();
      allow update: if isAdmin();

      match /votos/{uid} {
        allow read: if isAuth();
        // Solo el propio usuario puede crear su voto (una vez, controlado por transaction en cliente)
        allow create: if isAuth() && request.auth.uid == uid;
      }
    }

    // Opciones de votacion
    match /opciones_votacion/{opcionId} {
      allow read: if isAuth();
      allow create: if isAuth();
    }

    // Respuestas de votacion
    match /respuestas_votacion/{respuestaId} {
      allow read: if isAuth();
      allow create: if isAuth();
    }

    // Cuotas (modelo nuevo: cuotas/{cuotaId}/pagos/{userId})
    match /cuotas/{cuotaId} {
      // Lectura: cualquier miembro autenticado de la comunidad
      allow read: if isAuth() && belongsToCommunity(resource.data.comunidad_id);
      // Escritura: isAdminOfCommunity hace UN SOLO get() para verificar rol + comunidad
      allow create: if isAdminOfCommunity(request.resource.data.comunidad_id);
      allow update: if isAdminOfCommunity(resource.data.comunidad_id);
      allow delete: if isAdminOfCommunity(resource.data.comunidad_id);

      // Sub-colección pagos
      // allow create: isAuth() evita el get() extra por cada doc del writeBatch;
      // la seguridad real la garantiza que solo admin puede crear la cuota padre.
      match /pagos/{userId} {
        // El propio vecino ve su pago; admin/presidente ven todos
        allow read: if isAuth() && (request.auth.uid == userId || isAdmin());
        // writeBatch crea todos los pagos: solo necesitamos estar autenticados
        // (el frontend ya valida que solo admin llega aquí)
        allow create: if isAuth();
        // Marcar pagado: solo admin/presidente
        allow update: if isAdmin();
      }
    }

    // Cuotas vecinos (colección legacy — se mantiene para no romper datos existentes)
    match /cuotas_vecinos/{cuotaId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
    }

    // Mediaciones
    match /mediaciones/{mediacionId} {
      // Lectura: cualquier usuario autenticado (el filtrado por comunidad_id se hace en el cliente)
      // Nota: belongsToCommunity hace un get() extra que falla en queries LIST de Firestore
      allow read: if isAuth();
      // Crear: cualquier usuario autenticado (vecino inicia el flujo de IA)
      allow create: if isAuth();
      // Actualizar: el solicitante (para la fase IA), o admin/presidente/mediador de la comunidad
      allow update: if isAuth() && (
        request.auth.uid == resource.data.denunciante_id ||
        request.auth.uid == resource.data.solicitado_por ||
        canManageMediacion(resource.data.comunidad_id)
      );
    }

    // Notificaciones
    match /notificaciones/{notifId} {
      allow read: if isAuth() && request.auth.uid == resource.data.usuario_id;
      allow create: if isAuth();
      allow update: if isAuth() && request.auth.uid == resource.data.usuario_id;
    }

    // Consultas normativas
    match /consultas_normativas/{consultaId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
    }

    // Fotos de incidencias
    match /incidencias_fotos/{fotoId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow delete: if isAuth() && isAdmin();
    }

    // Push subscriptions
    match /push_subscriptions/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }
  }
}
