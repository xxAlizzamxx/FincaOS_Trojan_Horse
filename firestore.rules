rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Auth helpers ──────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    // Reads the caller's profile ONCE — all callers must be authenticated.
    // Cache the result in a local variable to avoid multiple get() calls.
    function profile() {
      return get(/databases/$(database)/documents/perfiles/$(request.auth.uid)).data;
    }

    function belongsToCommunity(comunidadId) {
      return isAuth() && profile().comunidad_id == comunidadId;
    }

    function isAdminOfCommunity(comunidadId) {
      let p = profile();
      return isAuth()
          && p.rol in ['admin', 'presidente']
          && p.comunidad_id == comunidadId;
    }

    function isMediadorOfCommunity(comunidadId) {
      let p = profile();
      return isAuth()
          && p.rol == 'mediador'
          && p.comunidad_id == comunidadId;
    }

    function canManageMediacion(comunidadId) {
      let p = profile();
      return isAuth()
          && p.comunidad_id == comunidadId
          && p.rol in ['admin', 'presidente', 'mediador'];
    }

    // ── Internal system collections (Admin SDK only) ──────────────────────
    // These are created/modified exclusively by server-side code.

    match /_rate_limits/{document=**} {
      allow read, write: if false;
    }

    match /_processed_webhooks/{document=**} {
      allow read, write: if false;
    }

    match /_email_dedup/{document=**} {
      allow read, write: if false;
    }

    // ── Admin audit logs ──────────────────────────────────────────────────
    // Escritura SOLO via Admin SDK (backend). Lectura solo para admin/presidente
    // de la misma comunidad — los vecinos nunca ven los logs de otros.

    match /admin_logs/{logId} {
      allow write: if false;  // backend-only (Admin SDK bypass rules)
      allow read:  if isAdminOfCommunity(resource.data.comunidad_id);
    }

    // ── Comunidades ───────────────────────────────────────────────────────
    // Read is public for the invite page.
    // Updates are restricted to the community's admin/presidente.
    // Create is allowed to any auth user (creates a new community).

    match /comunidades/{comunidadId} {
      allow read:   if true;
      allow create: if isAuth();
      // FIX: was `if isAuth()` — any user could rename any community
      allow update: if isAdminOfCommunity(comunidadId);

      match /notificaciones/{notifId} {
        allow read:   if isAuth() && belongsToCommunity(comunidadId);
        // Writes only via Admin SDK (server-side); no client rule needed.
      }
    }

    // ── Perfiles (datos públicos) ─────────────────────────────────────────
    // Read requires authentication. The invite page counts vecinos via
    // comunidades/{id}.num_viviendas — no longer needs unauthenticated reads.
    // Sensitive fields (email, telefono) live in perfiles_privados, not here.

    match /perfiles/{userId} {
      // Readable by any authenticated member of the SAME community.
      // Falls back to self-read for users without a community yet (onboarding).
      allow read: if isAuth()
                  && (request.auth.uid == userId
                      || (resource.data.comunidad_id != null
                          && resource.data.comunidad_id == profile().comunidad_id));
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if isAuth()
                    && (request.auth.uid == userId
                        || profile().rol in ['admin', 'presidente'])
                    // Prevent client from writing sensitive fields to public profile
                    && !('email'    in request.resource.data)
                    && !('plan'     in request.resource.data)
                    && !('ultimo_login' in request.resource.data);
    }

    // ── Perfiles privados ─────────────────────────────────────────────────
    // email, telefono, plan, ultimo_login, preferencias_notificaciones.
    // STRICTLY owner-only. No other user — not even admins — can read this.

    match /perfiles_privados/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

    // ── Categorías de incidencia (seed data, read-only) ───────────────────

    match /categorias_incidencia/{catId} {
      allow read:  if true;
      allow write: if false;
    }

    // ── Incidencias ───────────────────────────────────────────────────────
    // Any community member can read and create.
    // Updates from the client are allowed for community members; sensitive
    // state transitions are enforced server-side (Admin SDK).

    match /incidencias/{incidenciaId} {
      allow read:   if isAuth();
      allow create: if isAuth() && belongsToCommunity(request.resource.data.comunidad_id);
      allow update: if isAuth() && belongsToCommunity(resource.data.comunidad_id);
      // Deletes go through /api/eliminar which uses Admin SDK.

      match /afectados/{userId} {
        allow read:   if isAuth();
        // FIX: client writes validated by owner; actual quorum logic uses Admin SDK.
        allow create: if isAuth() && request.auth.uid == userId;
        allow delete: if isAuth() && request.auth.uid == userId;
      }
    }

    // ── Comentarios ───────────────────────────────────────────────────────
    // FIX: added autor_id == uid validation on create.
    // No client delete — admin uses Admin SDK.

    match /comentarios/{comentarioId} {
      allow read:   if isAuth();
      allow create: if isAuth()
                    && request.resource.data.autor_id == request.auth.uid;
      // Offline-synced comments use setDoc with a fixed ID; no special rule needed.
    }

    // ── Legacy afectados (kept for backwards compat — no new writes expected) ─

    match /incidencia_afectados/{afectadoId} {
      allow read:   if isAuth();
      // FIX: restrict create to the owner of the afectado record
      allow create: if isAuth()
                    && request.resource.data.vecino_id == request.auth.uid;
      allow delete: if isAuth()
                    && resource.data.vecino_id == request.auth.uid;
    }

    // ── Anuncios ──────────────────────────────────────────────────────────
    // FIX: create/delete now require admin or presidente.
    // Vecinos can only read.

    match /anuncios/{anuncioId} {
      allow read:   if isAuth();
      allow create: if isAuth() && profile().rol in ['admin', 'presidente'];
      allow update: if isAdminOfCommunity(resource.data.comunidad_id);
      allow delete: if isAuth()
                    && (resource.data.autor_id == request.auth.uid
                        || profile().rol in ['admin', 'presidente']);
    }

    // ── Documentos ───────────────────────────────────────────────────────

    match /documentos/{docId} {
      allow read:   if isAuth() && belongsToCommunity(resource.data.comunidad_id);
      allow create: if isAdminOfCommunity(request.resource.data.comunidad_id);
      allow delete: if isAdminOfCommunity(resource.data.comunidad_id);
    }

    // ── Votaciones ───────────────────────────────────────────────────────
    // Client update is limited to active votaciones (vecino casts vote via transaction).
    // Admin can do anything. Dangerous field changes are guarded by the transaction
    // in the client which only increments opciones[].votos.

    match /votaciones/{votacionId} {
      allow read:   if isAuth();
      allow create: if isAdminOfCommunity(request.resource.data.comunidad_id);
      allow update: if isAdminOfCommunity(resource.data.comunidad_id)
                 || (isAuth() && resource.data.activa == true
                     && belongsToCommunity(resource.data.comunidad_id));

      match /votos/{uid} {
        allow read:   if isAuth();
        allow create: if isAuth() && request.auth.uid == uid;
      }
    }

    match /opciones_votacion/{opcionId} {
      allow read:   if isAuth();
      allow create: if isAuth();
    }

    match /respuestas_votacion/{respuestaId} {
      allow read:   if isAuth();
      allow create: if isAuth();
    }

    // ── Cuotas ───────────────────────────────────────────────────────────

    match /cuotas/{cuotaId} {
      allow read:   if isAuth() && belongsToCommunity(resource.data.comunidad_id);
      allow create: if isAdminOfCommunity(request.resource.data.comunidad_id);
      allow update: if isAdminOfCommunity(resource.data.comunidad_id);
      allow delete: if isAdminOfCommunity(resource.data.comunidad_id);

      match /pagos/{userId} {
        allow read:   if isAuth() && (request.auth.uid == userId || profile().rol in ['admin', 'presidente']);
        allow create: if isAuth();
        allow update: if isAuth() && profile().rol in ['admin', 'presidente'];
      }
    }

    // Legacy cuotas collection
    match /cuotas_vecinos/{cuotaId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
    }

    // ── Mediaciones ──────────────────────────────────────────────────────

    match /mediaciones/{mediacionId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && (
        request.auth.uid == resource.data.denunciante_id ||
        request.auth.uid == resource.data.solicitado_por ||
        canManageMediacion(resource.data.comunidad_id)
      );
    }

    // ── Notificaciones de usuario ─────────────────────────────────────────

    match /notificaciones/{notifId} {
      allow read:   if isAuth() && request.auth.uid == resource.data.usuario_id;
      allow create: if isAuth();
      allow update: if isAuth() && request.auth.uid == resource.data.usuario_id;
    }

    // ── Consultas normativas ──────────────────────────────────────────────

    match /consultas_normativas/{consultaId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
    }

    // ── Fotos de incidencias ──────────────────────────────────────────────

    match /incidencias_fotos/{fotoId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      // FIX: admin OR the uploader can delete
      allow delete: if isAuth()
                    && (resource.data.autor_id == request.auth.uid
                        || profile().rol in ['admin', 'presidente']);
    }

    // ── Proveedores ───────────────────────────────────────────────────────
    // Lectura pública (vecinos ven el rating). Escritura solo via Admin SDK.

    match /proveedores/{proveedorId} {
      allow read: if isAuth();
      allow write: if false; // Admin SDK only

      match /reviews/{reviewId} {
        allow read: if isAuth();
        allow write: if false; // Admin SDK only (via /api/proveedores/review)
      }
    }

    // ── Push subscriptions ────────────────────────────────────────────────

    match /push_subscriptions/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

    // ── Analytics events ──────────────────────────────────────────────────
    // NO PII stored here — only action names, opaque IDs, and counters.
    // A user can only read their own events. Any authenticated user can create.
    // Admin analytics go through the Admin SDK (not these rules).

    match /analytics_events/{eventId} {
      allow read:   if isAuth() && request.auth.uid == resource.data.user_id;
      allow create: if isAuth()
                    && request.resource.data.user_id == request.auth.uid
                    && request.resource.data.keys().hasOnly([
                         'user_id', 'comunidad_id', 'event', 'created_at', 'metadata'
                       ]);
    }

    // ── Pagos (top-level, complementary to cuotas subcollection) ──────────

    match /pagos/{pagoId} {
      // Only the user who made the payment or an admin can read
      allow read:  if isAuth()
                   && (resource.data.usuario_id == request.auth.uid
                       || profile().rol in ['admin', 'presidente']);
      // Pagos are created by the server (Admin SDK) — no client create rule needed.
      allow write: if false;
    }
  }
}
